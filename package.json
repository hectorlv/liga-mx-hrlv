{
  "name": "liga-mx-hrlv",
  "description": "Web component liga-mx-hrlv following open-wc recommendations",
  "license": "MIT",
  "author": "liga-mx-hrlv",
  "version": "4.15.0",
  "type": "module",
  "packageManager": "pnpm@11.14.0",
  "scripts": {
    "lint": "eslint \"src/**/*.{ts,js,html}\"",
    "format": "eslint \"src/**/*.{ts,js,html}\" --fix && prettier \"src/**/*.{ts,js,html,css,json,md}\" --write",
    "build": "rimraf dist && rollup -c rollup.config.js --bundleConfigAsCjs && pnpm run analyze",
    "start:build:open": "pnpm run build && web-dev-server --root-dir dist --app-index index.html --open",
    "start:build": "pnpm run build && web-dev-server --root-dir dist --app-index index.html",
    "start": "web-dev-server --root-dir dist --app-index index.html",
    "typecheck": "tsc --noEmit",
    "analyze": "custom-elements-manifest analyze --globs \"src/**/*.{ts,js}\" --exclude \"**/dist/**\" --exclude \"**/node_modules/**\" --outdir dist"
  },
  "dependencies": {
    "@material/web": "^2.5.0",
    "firebase": "^12.16.0",
    "lit": "^3.3.3"
  },
  "devDependencies": {
    "@babel/preset-env": "^8.0.2",
    "@custom-elements-manifest/analyzer": "^0.11.0",
    "@eslint/js": "^10.0.1",
    "@open-wc/eslint-config": "^13.1.0",
    "@rollup/plugin-babel": "^7.1.0",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "@web/dev-server": "^1.0.0",
    "@web/rollup-plugin-html": "^4.0.0",
    "@web/rollup-plugin-import-meta-assets": "^3.0.0",
    "axe-core": "^4.12.1",
    "babel-plugin-template-html-minifier": "^4.1.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-lit": "^2.3.1",
    "playwright": "^1.61.1",
    "prettier": "^3.9.5",
    "rimraf": "^6.1.3",
    "rollup": "^4.62.2",
    "rollup-plugin-esbuild": "^6.2.1",
    "@rollup/plugin-image": "^3.0.3",
    "rollup-plugin-workbox": "^9.0.0",
    "typescript": "^7.0.2",
    "typescript-eslint": "^8.64.0",
    "serialize-javascript": "^7.0.7"
  },
  "eslintConfig": {
    "extends": [
      "@open-wc",
      "prettier"
    ]
  },
  "prettier": {
    "singleQuote": true,
    "arrowParens": "avoid"
  },
  "customElements": "dist/custom-elements.json",
  "overrides": {
    "glob": "11.1.0"
  }
}
