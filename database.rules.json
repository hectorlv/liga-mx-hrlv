{
  "rules": {
    ".read": false,
    ".write": false,
    "matches": {
      ".read": true,
      ".write": "auth != null && root.child('allowedWriters').child(auth.uid).exists()"
    },
    "teams": {
      ".read": true,
      ".write": "auth != null && root.child('allowedWriters').child(auth.uid).exists()"
    },
    "stadiums": {
      ".read": true,
      ".write": "auth != null && root.child('allowedWriters').child(auth.uid).exists()"
    },
    "players": {
      ".read": true,
      ".write": "auth != null && root.child('allowedWriters').child(auth.uid).exists()"
    },
    "u23NationalTeamCallups": {
      ".read": true,
      ".write": "auth != null && root.child('allowedWriters').child(auth.uid).exists()"
    },
    "allowedWriters": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": false
      }
    }
  }
}
